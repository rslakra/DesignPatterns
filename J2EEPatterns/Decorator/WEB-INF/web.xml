<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE web-app
    PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
    "http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>
	<filter>
		<filter-name>RequestInfoFilter</filter-name>
		<filter-class>com.devamatre.j2eepatterns.decorator.controller.RequestInfoFilter</filter-class>
	</filter>
	<filter>
		<filter-name>XmlStylesheetDecoratingFilter</filter-name>
		<filter-class>com.devamatre.j2eepatterns.decorator.controller.XmlStylesheetDecoratingFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>RequestInfoFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>
	<!-- Do NOT map this filter to /* (breaks welcome-file → JSP on Jetty). -->
	<filter-mapping>
		<filter-name>XmlStylesheetDecoratingFilter</filter-name>
		<url-pattern>*.xml</url-pattern>
	</filter-mapping>
	<servlet>
		<servlet-name>FrontController</servlet-name>
		<servlet-class>com.devamatre.j2eepatterns.decorator.controller.FrontController</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>FrontController</servlet-name>
		<url-pattern>/pages/*</url-pattern>
	</servlet-mapping>
	<session-config>
		<session-timeout>
			30
		</session-timeout>
	</session-config>
	<welcome-file-list>
		<welcome-file>login.jsp</welcome-file>
		<welcome-file>XMLView.xml</welcome-file>
	</welcome-file-list>
</web-app>
