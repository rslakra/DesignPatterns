<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE web-app
    PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
    "http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>
	<servlet>
		<servlet-name>FrontController</servlet-name>
		<servlet-class>com.devamatre.j2eepatterns.frontcontroller.controller.FrontController</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>ListController</servlet-name>
		<servlet-class>com.devamatre.j2eepatterns.frontcontroller.controller.ListController</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>FrontController</servlet-name>
		<url-pattern>/pages/*</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>ListController</servlet-name>
		<url-pattern>/servlets/ListController</url-pattern>
	</servlet-mapping>
	<session-config>
		<session-timeout>
			30
		</session-timeout>
	</session-config>
	<welcome-file-list>
		<welcome-file>login.jsp</welcome-file>
		<welcome-file>subscribe.html</welcome-file>
	</welcome-file-list>
</web-app>
