<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE web-app
    PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
    "http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>
	<servlet>
		<servlet-name>FrontController</servlet-name>
		<servlet-class>com.devamatre.j2eepatterns.compositeview.controller.FrontController</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>FrontController</servlet-name>
		<url-pattern>/pages/*</url-pattern>
	</servlet-mapping>
	<session-config>
		<session-timeout>
			30
		</session-timeout>
	</session-config>
	<welcome-file-list>
		<welcome-file>MainTemplate.jsp</welcome-file>
		<welcome-file>page1.html</welcome-file>
	</welcome-file-list>
	<taglib>
		<taglib-uri>/container</taglib-uri>
		<taglib-location>/WEB-INF/container.tld</taglib-location>
	</taglib>
</web-app>
