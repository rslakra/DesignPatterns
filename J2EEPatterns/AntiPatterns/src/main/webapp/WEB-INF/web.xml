<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE web-app
    PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
    "http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>
  <servlet>
    <servlet-name>MagicServlet</servlet-name>
    <servlet-class>com.rslakra.j2eepatterns.antipatterns.MagicServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>PersonServlet</servlet-name>
    <display-name>PersonServlet</display-name>
    <description>Default configuration created for servlet.</description>
    <servlet-class>com.rslakra.j2eepatterns.antipatterns.controller.PersonServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>LeakyServlet</servlet-name>
    <display-name>Leaky Servlet</display-name>
    <servlet-class>com.rslakra.j2eepatterns.antipatterns.LeakyServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MagicServlet</servlet-name>
    <url-pattern>/servlet/MagicServlet</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PersonServlet</servlet-name>
    <url-pattern>/servlet/PersonServlet</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>LeakyServlet</servlet-name>
    <url-pattern>/servlet/LeakyServlet</url-pattern>
  </servlet-mapping>
  <session-config>
    <session-timeout>
            30
        </session-timeout>
  </session-config>
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>LoginPage.jsp</welcome-file>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.htm</welcome-file>
  </welcome-file-list>
  <taglib>
    <taglib-uri>/jstl/core</taglib-uri>
    <taglib-location>/WEB-INF/c.tld</taglib-location>
  </taglib>
  <ejb-ref>
    <ejb-ref-name>ejb/PersonFacade</ejb-ref-name>
    <ejb-ref-type>Session</ejb-ref-type>
    <home>com.rslakra.j2eepatterns.antipatterns.ejbs.PersonFacadeHome</home>
    <remote>com.rslakra.j2eepatterns.antipatterns.ejbs.PersonFacade</remote>
    <ejb-link>PersonFacade</ejb-link>
  </ejb-ref>
  <ejb-ref>
    <ejb-ref-name>ejb/AddressBook</ejb-ref-name>
    <ejb-ref-type>Session</ejb-ref-type>
    <home>com.rslakra.j2eepatterns.antipatterns.ejbs.AddressBookHome</home>
    <remote>com.rslakra.j2eepatterns.antipatterns.ejbs.AddressBook</remote>
    <ejb-link>AddressBook</ejb-link>
  </ejb-ref>
  <ejb-ref>
    <ejb-ref-name>ejb/EJBPerson</ejb-ref-name>
    <ejb-ref-type>Entity</ejb-ref-type>
    <home>com.rslakra.j2eepatterns.antipatterns.ejbs.EJBPersonHome</home>
    <remote>com.rslakra.j2eepatterns.antipatterns.ejbs.EJBPerson</remote>
    <ejb-link>EJBPerson</ejb-link>
  </ejb-ref>
</web-app>
